APP_NAME="MYT Website"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://myt.co.tz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.myt.co.tz

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.myt.co.tz
MAIL_PORT=465
MAIL_USERNAME=info@myt.co.tz
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=info@myt.co.tz
MAIL_FROM_NAME="Mwambao Youth Technology"
CONTACT_NOTIFICATION_EMAIL=info@myt.co.tz

VITE_APP_NAME="${APP_NAME}"

ADMIN_NAME="Mwambao Admin"
ADMIN_EMAIL=admin@myt.co.tz
ADMIN_PASSWORD=
